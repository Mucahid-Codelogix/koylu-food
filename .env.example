APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Leave empty locally (uses public). Set to "spaces" on production if needed.
FILESYSTEM_UPLOAD_DISK=
UPLOAD_ENV=local
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DIRECTORY=
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ams3
AWS_BUCKET=
# Region API endpoint only — NOT the bucket URL (https://BUCKET.ams3...)
AWS_ENDPOINT=https://ams3.digitaloceanspaces.com
# Public file URLs (optional; auto-generated from bucket + region if empty)
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

EXACT_CLIENT_ID=
EXACT_CLIENT_SECRET=
EXACT_REDIRECT_URI="${APP_URL}/exact/oauth/callback"
EXACT_DIVISION=
EXACT_BASE_URL=https://start.exactonline.nl
EXACT_CUSTOMER_SEARCH_CODE_PREFIX=KOYLU
EXACT_CUSTOMER_VAT_CODE_NL=
EXACT_CUSTOMER_VAT_CODE_BE=
EXACT_CUSTOMER_VAT_CODE_EXEMPT=
EXACT_ITEM_CODE_PREFIX=KOYLU
EXACT_ITEM_UNIT=kg
EXACT_ITEM_GROUP=
EXACT_ITEM_VAT_CODE_LOW=
EXACT_ITEM_VAT_CODE_HIGH=
EXACT_SUPPLIER_SEARCH_CODE_PREFIX=KOYLU-S
EXACT_SUPPLIER_VAT_CODE=
EXACT_INVOICE_JOURNAL=70
EXACT_INVOICE_PRINT_ON_PUSH=true
EXACT_INVOICE_VAT_CODE_EXEMPT=
EXACT_INVOICE_VAT_CODE_LOW=
EXACT_INVOICE_VAT_CODE_HIGH=
EXACT_ALERT_MAIL_TO=
EXACT_ALERT_FAILURE_THRESHOLD=3
